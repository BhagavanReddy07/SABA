# --- Storage ---
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql://saba:saba_password@localhost:5432/saba
# Deploying? Use a free hosted Postgres instead (Neon: https://neon.tech) —
# paste its pooled connection string, e.g.
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/saba?sslmode=require

# Optional Tier-1 cache. Leave unset on free hosting (Postgres fallback kicks in),
# or use a free Upstash Redis URL (https://upstash.com).
REDIS_URL=redis://localhost:6380

# --- Auth ---
# Any long random string. Generate one with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_SECRET=replace_with_a_long_random_secret

# --- AI (optional — without a key SABA runs in demo mode) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Semantic memory (optional — without it Tier 3 recall is skipped) ---
# https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX=saba-memory
