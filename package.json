{
  "name": "saba",
  "version": "1.0.0",
  "description": "Personal AI assistant with a 3-tier memory architecture (Redis + PostgreSQL + Pinecone)",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "db:init": "node scripts/db.mjs",
    "db:reset": "node scripts/db.mjs reset",
    "setup": "npm run docker:up && npm run db:init"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^6.1.2",
    "bcrypt": "^6.0.0",
    "lucide-react": "^0.475.0",
    "next": "15.3.3",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "redis": "^5.8.3",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.5.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
